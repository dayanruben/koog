flowchart TD
    Start([nodeStart])
    Classify[classifyRequest]
    Check[checkRequest]
    Order[orderStatusFlow]
    Change[changeAddressFlow]
    Refund[refundFlow]
    MaybeCompress[maybeCompressHistory]
    Compress[compressLLMHistory]
    Finish([nodeFinish])

    Start --> Classify

    Classify -- "isSuccess" --> Check
    Classify -- "isFailure" --> MaybeCompress

    Check -- "needsMoreInfo" --> MaybeCompress
    Check -- "intent = ORDER_STATUS" --> Order
    Check -- "intent = CHANGE_ADDRESS" --> Change
    Check -- "intent = REFUND" --> Refund

    Order --> MaybeCompress
    Change --> MaybeCompress
    Refund --> MaybeCompress

    MaybeCompress -- "tooManyTokensSpent" --> Compress
    MaybeCompress -- "!tooManyTokensSpent" --> Finish

    Compress --> Finish
