flowchart TD
    Start([nodeStart])
    Classify[classifyRequest]
    Check[checkContext]
    Ask[askForMoreInfo]
    Order[orderStatusFlow]
    Change[changeAddressFlow]
    Refund[refundFlow]
    FAQ[faqFlow]
    MAYBE_COMPRESS[maybeCompressHistory]
    COMPRESS[compressLLMHistory]
    Finish([nodeFinish])

    Start --> Classify

    Classify -- "isSuccess" --> Check
    Classify -- "isFailure" --> Finish

    Check -- "needsMoreInfo" --> Ask
    Check -- "intent = ORDER_STATUS" --> Order
    Check -- "intent = CHANGE_ADDRESS" --> Change
    Check -- "intent = REFUND_OR_RETURN" --> Refund
    Check -- "intent = OTHER" --> FAQ

    Ask --> MAYBE_COMPRESS
    Order --> MAYBE_COMPRESS
    Change --> MAYBE_COMPRESS
    Refund --> MAYBE_COMPRESS
    FAQ --> MAYBE_COMPRESS

    MAYBE_COMPRESS -- "tooManyTokensSpent" --> COMPRESS
    MAYBE_COMPRESS -- "!tooManyTokensSpent" --> Finish
    COMPRESS --> Finish
